# Copy to .env and fill in values

# Postgres credentials (used by both the db and app containers in Docker Compose)
POSTGRES_USER=atc
POSTGRES_PASSWORD=atc
POSTGRES_DB=atc

# Override the database URL entirely (optional).
# Defaults to postgres via Docker Compose internal hostname (db).
# Uncomment and set to use SQLite instead:
# DATABASE_URL=sqlite+aiosqlite:///./atc.db
# Or set explicitly for postgres (e.g. when running outside Docker):
# DATABASE_URL=postgresql+asyncpg://atc:atc@localhost:5432/atc

# App token for privileged UI actions (tool upload/delete).
# Leave blank to auto-generate a fresh token each startup.
# APP_TOKEN=your-secret-token-here

# Directory where tool YAML definitions are stored (default: tools/)
# TOOLS_DIR=tools

# Public base URL used in webhook callback URLs
# PUBLIC_BASE_URL=http://localhost:8000/
